-  ~NoDestruct() = default;
-
-  T* operator->() { return get(); }
-  const T* operator->() const { return get(); }
-  T& operator*() { return *get(); }
-  const T& operator*() const { return *get(); }
-
-  T* get() { return reinterpret_cast<T*>(&space_); }
-  const T* get() const { return reinterpret_cast<const T*>(&space_); }
-
- private:
-  alignas(T) char space_[sizeof(T)];
-};
