diff --git a/hermetic_actions.bzl b/hermetic_actions.bzl
new file mode 100644
index 0000000..8318b61
--- /dev/null
+++ b/hermetic_actions.bzl
@@ -0,0 +1,33 @@
+"""Hermetic file-generation actions for the zstd-jni overlay."""
+
+def _copy_file_impl(ctx):
+    ctx.actions.symlink(
+        output = ctx.outputs.out,
+        target_file = ctx.file.src,
+    )
+
+def _write_version_java_impl(ctx):
+    ctx.actions.write(
+        output = ctx.outputs.out,
+        content = """package com.github.luben.zstd.util;
+
+public class ZstdVersion {
+\tpublic static final String VERSION = \"1.5.6-9\";
+}
+""",
+    )
+
+copy_file = rule(
+    implementation = _copy_file_impl,
+    attrs = {
+        "src": attr.label(allow_single_file = True, mandatory = True),
+        "out": attr.output(mandatory = True),
+    },
+)
+
+write_version_java = rule(
+    implementation = _write_version_java_impl,
+    attrs = {
+        "out": attr.output(mandatory = True),
+    },
+)
