# Wrapper script to run the native-image Bazel prototype in the tests.
#
bazel_bin="$(rlocation _main/src/bazel_native 2>/dev/null || true)"
if [[ -z "${bazel_bin}" ]]; then
  bazel_bin="$(rlocation io_bazel/src/bazel_native 2>/dev/null || true)"
fi
if [[ -z "${bazel_bin}" ]]; then
  echo "Unable to locate native-image Bazel binary in runfiles" >&2
  exit 1
fi
# unset runfiles environment so that the "inner bazel"
# has to detect its own runfiles
unset RUNFILES_DIR
unset RUNFILES_MANIFEST_FILE
unset RUNFILES_MANIFEST_ONLY
while IFS= read -r function_name; do
  export -n -f "$function_name" 2>/dev/null || true
done < <(compgen -A function)

extra_startup_args=()
server_jvm_out="${BAZEL_NATIVE_IMAGE_SERVER_JVM_OUT:-}"
if [[ -z "$server_jvm_out" \
      && -n "${BAZEL_NATIVE_IMAGE_CAPTURE_SERVER_LOGS:-}" \
      && -n "${TEST_UNDECLARED_OUTPUTS_DIR:-}" ]]; then
  server_log_dir="${TEST_UNDECLARED_OUTPUTS_DIR}/native-image-server"
  mkdir -p "$server_log_dir"
  server_jvm_out="${server_log_dir}/jvm.out"
fi

if [[ -n "$server_jvm_out" ]]; then
  extra_startup_args+=(--server_jvm_out="$server_jvm_out")
fi
if [[ -n "${BAZEL_NATIVE_IMAGE_CLIENT_DEBUG:-}" ]]; then
  extra_startup_args+=(--client_debug)
fi
exec "$bazel_bin" \
  --nohome_rc \
  --nosystem_rc \
  --bazelrc="$TEST_TMPDIR/bazelrc" \
  "${extra_startup_args[@]}" \
  "$@"
